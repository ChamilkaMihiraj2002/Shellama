{
  "name": "shellama",
  "module": "index.tsx",
  "type": "module",
  "private": true,
  "bin": {
    "shellama": "./index.tsx"
  },
  "scripts": {
    "build:mac": "bun build --compile --target=bun-darwin-arm64 ./index.tsx --outfile ./dist/shellama-macos-arm64",
    "build:mac:intel": "bun build --compile --target=bun-darwin-x64 ./index.tsx --outfile ./dist/shellama-macos-x64",
    "build:mac:all": "bun run build:mac && bun run build:mac:intel",
    "build:win": "bun build --compile --target=bun-windows-x64 ./index.tsx --outfile ./dist/shellama.exe",
    "build:win:baseline": "bun build --compile --target=bun-windows-x64-baseline ./index.tsx --outfile ./dist/shellama.exe"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/react": "^19.2.14"
  },
  "peerDependencies": {
    "typescript": "^6.0.2"
  },
  "dependencies": {
    "ink": "^6.8.0",
    "ink-select-input": "^6.2.0",
    "ink-spinner": "^5.0.0",
    "ink-text-input": "^6.0.0",
    "ollama": "^0.6.3",
    "react": "^19.2.4",
    "react-devtools-core": "^7.0.1",
    "zod": "^4.3.6"
  }
}
